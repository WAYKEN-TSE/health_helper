    {
      "id": "pre01",
      "name": "紫薯蒸蛋",
      "mealTag": [
        "pre_workout",
        "rest_day"
      ],
      "suitableMeals": [
        "breakfast",
        "lunch"
      ],
      "ingredientIds": [
